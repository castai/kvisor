FROM cgr.dev/chainguard/static:latest@sha256:77d8b8925dc27970ec2f48243f44c7a260d52c49cd778288e4ee97566e0cb75b

# the agent needs to run as root, there is no way around this
USER 0

ARG TARGETARCH
COPY bin/kvisor-agent-$TARGETARCH /usr/local/bin/kvisor-agent

# License and attribution bundle (Apache-2.0 §4(a), §4(c)).
COPY LICENSE                                  /licenses/LICENSE
COPY NOTICE.md                                /licenses/NOTICE.md
COPY licenses/agent/THIRD_PARTY_NOTICES.md    /licenses/THIRD_PARTY_NOTICES.md
COPY licenses/GPL-2.0.txt                     /licenses/GPL-2.0.txt

LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.source="https://github.com/castai/kvisor"

ENTRYPOINT ["/usr/local/bin/kvisor-agent"]
